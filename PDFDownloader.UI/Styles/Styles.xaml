<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Section Border Style -->
    <Style x:Key="SectionBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Surface}"></Setter>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Primary}"></Setter>
        <Setter Property="BorderThickness" Value="1"></Setter>
        <Setter Property="CornerRadius" Value="6"></Setter>
        <Setter Property="Margin" Value="10"></Setter>
        <Setter Property="Padding" Value="10"></Setter>
    </Style>
    
    <!-- Downloading State TextBlock Style -->
    <Style x:Key="StateTextStyle" TargetType="TextBlock">
        <Style.Triggers>
            <DataTrigger Binding="{Binding State}" Value="Ready">
                <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"></Setter>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="Downloading">
                <Setter Property="Foreground" Value="{StaticResource Brush.Warning}"></Setter>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="Finished">
                <Setter Property="Foreground" Value="{StaticResource Brush.Success}"></Setter>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>