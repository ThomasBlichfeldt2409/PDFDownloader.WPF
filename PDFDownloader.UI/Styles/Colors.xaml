<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Base Colors -->
    <Color x:Key="Color.Primary">#2C3E50</Color>
    <Color x:Key="Color.Accent">#3498DB</Color>
    <Color x:Key="Color.Success">#27AE60</Color>
    <Color x:Key="Color.Warning">#F39C12</Color>

    <Color x:Key="Color.Background">#F1F5F9</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>

    <Color x:Key="Color.TextPrimary">#1F2933</Color>
    <Color x:Key="Color.TextSecondary">#6B7280</Color>

</ResourceDictionary>