<UserControl x:Class="PDFDownloader.UI.Views.ProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Border Style="{StaticResource SectionBorderStyle}">
        <Grid>
            <!-- Progress Layout -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
                <ColumnDefinition Width="6*"></ColumnDefinition>
                <ColumnDefinition Width="12*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>
            
            <!-- Succeeded TextBlock -->
            <TextBlock Grid.Column="0"
                       Grid.Row="0"
                       Text="Succeeded:"
                       Foreground="{StaticResource Brush.Success}"
                       FontSize="12"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left">
            </TextBlock>
            <TextBlock Grid.Column="1"
                       Grid.Row="0"
                       Text="{Binding Succeeded}"
                       Foreground="{StaticResource Brush.Success}"
                       FontSize="12"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left">
            </TextBlock>

            <!-- Failed TextBlock -->
            <TextBlock Grid.Column="0"
                       Grid.Row="1"
                       Text="Failed:"
                       Foreground="{StaticResource Brush.Failed}"
                       FontSize="12"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left">
            </TextBlock>
            <TextBlock Grid.Column="1"
                       Grid.Row="1"
                       Text="{Binding Failed}"
                       Foreground="{StaticResource Brush.Failed}"
                       FontSize="12"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left">
            </TextBlock>
            
            <!-- Downloading Progress -->
            <TextBlock Grid.Column="3"
                       Grid.Row="0"
                       Text="Downloading Progress"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       FontSize="12"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left">
            </TextBlock>
            <TextBlock Grid.Column="4"
                       Grid.Row="1"
                       Text="{Binding Percentage, StringFormat={}{0:F1}%}"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       FontSize="12"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center">
            </TextBlock>
            
            <!-- Progress Bar -->
            <ProgressBar Grid.Row="1"
                         Grid.Column="3"
                         Height="15"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding Percentage}"
                         Background="{StaticResource Brush.Background}"
                         Foreground="{StaticResource Brush.Accent}"
                         BorderBrush="{StaticResource Brush.TextSecondary}"
                         BorderThickness="1">
            </ProgressBar>
            

        </Grid>
    </Border>
    
</UserControl>
